// Outil de Gestion de Chantier - Schéma de base de données

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// AUTHENTIFICATION & UTILISATEURS
// =====================================================

enum Role {
  ADMIN
  /// Conducteur de travaux : voit les prix matériel / locations / commandes,
  /// fait OPC / OPR, valide les demandes, pilote le planning. Ne voit pas
  /// la paie complète. Intermédiaire entre ADMIN et CHEF.
  CONDUCTEUR
  /// Chef de chantier = ouvrier de terrain. Voit son(ses) chantier(s),
  /// son fil, son équipe. Aucun prix nulle part. Peut : pointer, déclarer
  /// incidents, demander matériel, faire rapports avec photos, gérer
  /// sorties/retours matériel.
  CHEF
  CLIENT
}

enum UserStatus {
  PENDING
  ACTIVE
  REVOKED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(CHEF)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Visibilité côté CLIENT — l'admin contrôle ce que ce client voit.
  // Pour ADMIN/CHEF, ces flags sont ignorés (ils voient tout).
  showJournal       Boolean @default(true)
  showIncidents     Boolean @default(true)
  showPlans         Boolean @default(true)
  showRapportsHebdo Boolean @default(true)

  // 2FA TOTP (RFC 6238). `totpSecret` est en clair (encryption au repos
  // via la BDD/disk). `totpEnabled` reste false tant que le user n'a pas
  // vérifié son premier code (anti-enrôlement raté). Backup codes hashés
  // SHA-256, à usage unique : on vérifie le hash et on retire le code.
  totpEnabled      Boolean  @default(false)
  totpSecret       String?
  totpBackupCodes  String[] @default([])

  chantiersGeres     Chantier[]           @relation("ChefChantier")
  chantiersClient    Chantier[]           @relation("ChantierClients")
  passwordResets     PasswordResetToken[]
  rapportsCrees      RapportChantier[]
  incidentsRapportes Incident[]           @relation("IncidentReporter")
  incidentsResolus   Incident[]           @relation("IncidentResolver")
  demandesFaites     DemandeMateriel[]    @relation("DemandeRequester")
  demandesValidees   DemandeMateriel[]    @relation("DemandeApprover")
  notifications      Notification[]
  journalMessages    JournalMessage[]
  plansUploaded      PlanChantier[]
  readStates         UserReadState[]
  pushSubscriptions  PushSubscription[]
  chantierPins       UserChantierPin[]
  auditEntries       AuditEntry[]
  messageReactions   MessageReaction[]
  canauxCrees        Canal[]              @relation("CanalCreateur")
  messageTags        MessageTag[]         @relation("TagAuteur")
}

// Token à usage unique pour réinitialiser un mot de passe.
// `tokenHash` = hash SHA-256 du token (le token clair est dans l'URL envoyée).
// On ne stocke jamais le token clair en base.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// =====================================================
// CHANTIERS, ÉQUIPES, OUVRIERS
// =====================================================

enum StatutChantier {
  PLANIFIE
  EN_COURS
  PAUSE
  TERMINE
  ANNULE
}

model Chantier {
  id              String         @id @default(cuid())
  nom             String
  adresse         String?
  description     String?
  dateDebut       DateTime?
  dateFin         DateTime?
  statut          StatutChantier @default(PLANIFIE)
  budgetEspeces   Decimal        @default(0) @db.Decimal(12, 2)
  budgetVirement  Decimal        @default(0) @db.Decimal(12, 2)
  chefId          String?
  chef            User?          @relation("ChefChantier", fields: [chefId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  archivedAt       DateTime?

  equipes          Equipe[]
  pointages        Pointage[]
  sortiesMateriel  SortieMateriel[]
  locations        LocationPret[]
  commandes        Commande[]
  taches           Tache[]
  rapports         RapportChantier[]
  incidents        Incident[]
  demandesMateriel DemandeMateriel[]
  clients          User[]            @relation("ChantierClients")
  journalMessages  JournalMessage[]
  plans            PlanChantier[]
  rapportsHebdo    RapportHebdo[]
  pvReceptions     PvReception[]
  labels           Label[]
  sections         Section[]
  pins             UserChantierPin[]
  canaux           Canal[]
}

model Equipe {
  id          String   @id @default(cuid())
  nom         String
  chantierId  String?
  chantier    Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ouvriers        Ouvrier[]
  sortiesMateriel SortieMateriel[]
  taches          Tache[]
}

enum TypeContrat {
  FIXE
  JOUR
  SEMAINE
  MOIS
  FORFAIT
}

enum ModePaie {
  JOUR
  SEMAINE
  MOIS
}

model Ouvrier {
  id           String      @id @default(cuid())
  nom          String
  prenom       String?
  telephone    String?
  photo        String?
  typeContrat  TypeContrat
  tarifBase    Decimal     @db.Decimal(10, 2)
  modePaie     ModePaie    @default(MOIS)
  actif        Boolean     @default(true)
  equipeId     String?
  equipe       Equipe?     @relation(fields: [equipeId], references: [id], onDelete: SetNull)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  pointages        Pointage[]
  avances          Avance[]
  paiements        Paiement[]
  outilsPersonnels OutilPersonnel[]
  tachesAssignees  TacheOuvrier[]
}

/// Singleton (id="singleton") qui stocke les préférences de l'app —
/// modifiables par un admin depuis /parametres.
model AppSettings {
  id              String   @id @default("singleton")
  joursParMois    Int      @default(23)
  joursParSemaine Int      @default(6)
  modePaieDefault String   @default("ESPECES") // ESPECES | VIREMENT
  nomEntreprise   String?
  updatedAt       DateTime @updatedAt
}

model Pointage {
  id              String   @id @default(cuid())
  ouvrierId       String
  ouvrier         Ouvrier  @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  joursTravailles Decimal  @default(1) @db.Decimal(4, 2)
  chantierId      String?
  chantier        Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  note            String?
  photo           String?
  createdAt       DateTime @default(now())

  @@unique([ouvrierId, date])
  @@index([date])
  @@index([chantierId])
}

enum ModePaiement {
  ESPECES
  VIREMENT
}

model Avance {
  id         String       @id @default(cuid())
  ouvrierId  String
  ouvrier    Ouvrier      @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  montant    Decimal      @db.Decimal(10, 2)
  date       DateTime     @db.Date
  mode       ModePaiement @default(ESPECES)
  reglee     Boolean      @default(false)
  paiementId String?
  paiement   Paiement?    @relation(fields: [paiementId], references: [id], onDelete: SetNull)
  note       String?
  createdAt  DateTime     @default(now())

  @@index([ouvrierId])
  @@index([reglee])
}

enum StatutPaiement {
  CALCULE
  PAYE
  ANNULE
}

model Paiement {
  id              String         @id @default(cuid())
  ouvrierId       String
  ouvrier         Ouvrier        @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  periodeDebut    DateTime       @db.Date
  periodeFin      DateTime       @db.Date
  joursTravailles Decimal        @db.Decimal(6, 2)
  montantBrut     Decimal        @db.Decimal(10, 2)
  avancesDeduites Decimal        @default(0) @db.Decimal(10, 2)
  retenueOutil    Decimal        @default(0) @db.Decimal(10, 2)
  montantNet      Decimal        @db.Decimal(10, 2)
  mode            ModePaiement   @default(ESPECES)
  date            DateTime       @db.Date
  statut          StatutPaiement @default(CALCULE)
  note            String?
  createdAt       DateTime       @default(now())

  avances        Avance[]
  retenuesOutils RetenueOutil[]

  @@index([ouvrierId, periodeDebut])
}

model OutilPersonnel {
  id         String   @id @default(cuid())
  ouvrierId  String
  ouvrier    Ouvrier  @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  nom        String
  prixTotal  Decimal  @db.Decimal(10, 2)
  mensualite Decimal  @db.Decimal(10, 2)
  restantDu  Decimal  @db.Decimal(10, 2)
  dateAchat  DateTime @db.Date
  solde      Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  retenues RetenueOutil[]

  @@index([ouvrierId, solde])
}

model RetenueOutil {
  id               String         @id @default(cuid())
  outilPersonnelId String
  outilPersonnel   OutilPersonnel @relation(fields: [outilPersonnelId], references: [id], onDelete: Cascade)
  paiementId       String
  paiement         Paiement       @relation(fields: [paiementId], references: [id], onDelete: Cascade)
  montant          Decimal        @db.Decimal(10, 2)
  createdAt        DateTime       @default(now())
}

// =====================================================
// MATÉRIEL, ACCESSOIRES, SORTIES, LOCATIONS
// =====================================================

enum StatutMateriel {
  DISPO
  SORTI
  EN_LOCATION
  HS
  PERDU
}

enum PossesseurMateriel {
  ENTREPRISE
  LOCATION
  PRET
}

model Materiel {
  id          String             @id @default(cuid())
  nomCommun   String
  marque      String?
  modele      String?
  numeroSerie String?
  photo       String?
  statut      StatutMateriel     @default(DISPO)
  possesseur  PossesseurMateriel @default(ENTREPRISE)
  prixAchat   Decimal?           @db.Decimal(10, 2)
  dateAchat   DateTime?          @db.Date
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  accessoires Accessoire[]
  sorties     SortieMateriel[]
  locations   LocationPret[]

  @@index([statut])
  @@index([possesseur])
}

model Accessoire {
  id         String   @id @default(cuid())
  materielId String
  materiel   Materiel @relation(fields: [materielId], references: [id], onDelete: Cascade)
  type       String
  nom        String
  quantite   Int      @default(1)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum EtatRetour {
  BON
  USE
  CASSE
  MANQUANT
}

model SortieMateriel {
  id         String      @id @default(cuid())
  materielId String
  materiel   Materiel    @relation(fields: [materielId], references: [id], onDelete: Cascade)
  equipeId   String?
  equipe     Equipe?     @relation(fields: [equipeId], references: [id], onDelete: SetNull)
  chantierId String?
  chantier   Chantier?   @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  dateSortie DateTime    @default(now())
  dateRetour DateTime?
  etatRetour EtatRetour?
  note       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([materielId, dateRetour])
  @@index([equipeId])
}

enum TypeLocationPret {
  LOCATION
  PRET
}

model LocationPret {
  id             String           @id @default(cuid())
  materielId     String?
  materiel       Materiel?        @relation(fields: [materielId], references: [id], onDelete: SetNull)
  designation    String
  type           TypeLocationPret
  fournisseurNom String
  chantierId     String?
  chantier       Chantier?        @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  dateDebut      DateTime         @db.Date
  dateFinPrevue  DateTime         @db.Date
  dateRetourReel DateTime?        @db.Date
  coutJour       Decimal          @default(0) @db.Decimal(10, 2)
  coutTotal      Decimal          @default(0) @db.Decimal(10, 2)
  cloture        Boolean          @default(false)
  note           String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([cloture, dateFinPrevue])
}

// =====================================================
// COMMANDES
// =====================================================

enum StatutCommande {
  COMMANDEE
  EN_LIVRAISON
  LIVREE
  ANNULEE
}

model Commande {
  id                  String         @id @default(cuid())
  chantierId          String
  chantier            Chantier       @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  fournisseur         String
  reference           String?
  coutTotal           Decimal        @default(0) @db.Decimal(12, 2)
  dateCommande        DateTime       @db.Date
  dateLivraisonPrevue DateTime?      @db.Date
  dateLivraisonReelle DateTime?      @db.Date
  statut              StatutCommande @default(COMMANDEE)
  mode                ModePaiement   @default(VIREMENT)
  note                String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  lignes LigneCommande[]

  // Soft-delete : marqué supprimé mais conservé 30 jours dans la corbeille
  deletedAt DateTime?

  @@index([chantierId])
  @@index([statut])
  @@index([deletedAt])
}

model LigneCommande {
  id           String   @id @default(cuid())
  commandeId   String
  commande     Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  designation  String
  quantite     Decimal  @default(1) @db.Decimal(10, 2)
  prixUnitaire Decimal  @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(12, 2)
}

// =====================================================
// PLANNING / TÂCHES
// =====================================================

enum StatutTache {
  A_FAIRE
  EN_COURS
  TERMINEE
  BLOQUEE
}

model Tache {
  id          String      @id @default(cuid())
  chantierId  String
  chantier    Chantier    @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  equipeId    String?
  equipe      Equipe?     @relation(fields: [equipeId], references: [id], onDelete: SetNull)
  nom         String
  description String?
  dateDebut   DateTime    @db.Date
  dateFin     DateTime    @db.Date
  avancement  Int         @default(0)
  statut      StatutTache @default(A_FAIRE)
  /// Priorité Todoist-style : 1 = P1 (urgent, rouge), 2 = P2 (haute, orange),
  /// 3 = P3 (moyenne, bleu), 4 = P4 (par défaut, gris).
  priorite    Int         @default(4)
  /// Sous-tâche : pointe vers la tâche parente. Cascade delete.
  parentId    String?
  parent      Tache?      @relation("TacheSousTaches", fields: [parentId], references: [id], onDelete: Cascade)
  enfants     Tache[]     @relation("TacheSousTaches")
  /// Ordre manuel dans la liste (drag-to-reorder dans l'UI).
  ordre       Int         @default(0)
  /// Groupe de regroupement façon Todoist (ex: "Gros œuvre", "Finitions").
  /// Par chantier ; SetNull si la section est supprimée.
  sectionId   String?
  section     Section?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  dependances Tache[]     @relation("TacheDependance")
  dependants  Tache[]     @relation("TacheDependance")
  labels      TacheLabel[]
  ouvriers    TacheOuvrier[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Récurrence (format RFC 5545 RRULE, ex: "FREQ=WEEKLY;BYDAY=MO,FR").
  // Quand la tâche est marquée terminée, une nouvelle occurrence est
  // créée automatiquement à la prochaine date prévue par la règle.
  recurrence  String?
  /// Tâche parente de la série récurrente (pour traçage/historique).
  recurrenceParentId String?

  // Soft-delete : marqué supprimé mais conservé 30 jours dans la corbeille
  deletedAt   DateTime?

  @@index([chantierId])
  @@index([dateDebut, dateFin])
  @@index([parentId])
  @@index([sectionId])
  @@index([deletedAt])
}

/// Affectation m2m d'ouvriers sur une tâche. La tâche garde toujours son
/// équipe (vue agrégée), mais cette table permet de cibler des ouvriers
/// individuels — utile pour les sous-tâches précises ou les forfaits.
model TacheOuvrier {
  tacheId   String
  ouvrierId String
  tache     Tache   @relation(fields: [tacheId], references: [id], onDelete: Cascade)
  ouvrier   Ouvrier @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([tacheId, ouvrierId])
  @@index([ouvrierId])
}

/// Section pour grouper les tâches dans un chantier (Todoist-like).
/// Exemples : "Gros œuvre", "Second œuvre", "Finitions", "VRD".
model Section {
  id         String   @id @default(cuid())
  chantierId String
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  nom        String
  couleur    String?  // hex optionnel pour accent visuel
  ordre      Int      @default(0)
  taches     Tache[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chantierId])
}

/// Étiquette / tag pour catégoriser les tâches (sécurité, urgent, livraison...).
/// Globale par défaut (chantierId null) ou rattachée à un chantier.
model Label {
  id          String       @id @default(cuid())
  nom         String
  couleur     String       @default("#3b82f6") // hex
  chantierId  String?
  chantier    Chantier?    @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  taches      TacheLabel[]
  createdAt   DateTime     @default(now())

  @@index([chantierId])
}

/// Table de jointure many-to-many Tache ↔ Label.
model TacheLabel {
  tacheId String
  labelId String
  tache   Tache @relation(fields: [tacheId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([tacheId, labelId])
  @@index([labelId])
}

// =====================================================
// RAPPORTS DE CHANTIER (DSR — Daily Site Report)
// =====================================================

enum Meteo {
  SOLEIL
  NUAGEUX
  PLUIE
  ORAGE
  NEIGE
  GEL
  VENT_FORT
}

/// Rapport journalier rédigé par un chef de chantier (ou admin) sur
/// un chantier : ce qui a été fait, météo, photos prises sur site,
/// nombre d'ouvriers présents. Permet à l'admin de suivre l'avancement
/// sans être sur place.
model RapportChantier {
  id          String   @id @default(cuid())
  chantierId  String
  chantier    Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  date        DateTime @db.Date
  meteo       Meteo?
  texte       String
  photos      String[] @default([])
  nbOuvriers  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft-delete : marqué supprimé mais conservé 30 jours dans la corbeille
  deletedAt   DateTime?

  @@index([chantierId, date(sort: Desc)])
  @@index([authorId])
  @@index([deletedAt])
}

// =====================================================
// INCIDENTS / ISSUES (problèmes terrain)
// =====================================================

enum CategorieIncident {
  MATERIEL_MANQUANT
  PANNE
  METEO
  RETARD_FOURNISSEUR
  SECURITE
  ACCIDENT
  CONFLIT
  AUTRE
}

enum NiveauGravite {
  INFO
  ATTENTION
  URGENT
}

enum StatutIncident {
  OUVERT
  EN_COURS
  RESOLU
}

/// Incident remonté depuis le terrain : matériel manquant, panne,
/// problème météo, retard fournisseur, sécurité, accident, etc.
/// Permet aux chefs de signaler les blocages, et aux admins de suivre
/// la résolution.
model Incident {
  id             String            @id @default(cuid())
  chantierId     String?
  chantier       Chantier?         @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  reporterId     String
  reporter       User              @relation("IncidentReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  titre          String
  description    String
  categorie      CategorieIncident
  gravite        NiveauGravite     @default(ATTENTION)
  statut         StatutIncident    @default(OUVERT)
  resolutionNote String?
  resolvedAt     DateTime?
  resolverId     String?
  resolver       User?             @relation("IncidentResolver", fields: [resolverId], references: [id], onDelete: SetNull)
  photos         String[]          @default([])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([chantierId])
  @@index([statut])
  @@index([createdAt(sort: Desc)])
}

// =====================================================
// NOTIFICATIONS IN-APP
// =====================================================

enum NotificationType {
  RAPPORT_CREE
  INCIDENT_OUVERT
  INCIDENT_RESOLU
  DEMANDE_CREEE
  DEMANDE_APPROUVEE
  DEMANDE_REFUSEE
  DEMANDE_COMMANDEE
  PAIEMENT_GENERE
  USER_PENDING
  AUTRE
}

/// Notification simple pour l'utilisateur, affichée dans la cloche en
/// haut de page. Créée par notify() depuis les server actions concernées.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt(sort: Desc)])
}

// =====================================================
// DEMANDES DE MATÉRIEL (chef demande → admin valide → commande)
// =====================================================

enum StatutDemandeMateriel {
  DEMANDEE
  APPROUVEE
  REFUSEE
  COMMANDEE
}

/// Demande de matériel formulée par un chef de chantier. L'admin valide
/// (ou refuse), puis la transforme en commande quand elle part chez le
/// fournisseur. Workflow propre : trace tout, évite les SMS perdus.
model DemandeMateriel {
  id           String                 @id @default(cuid())
  chantierId   String
  chantier     Chantier               @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  requesterId  String
  requester    User                   @relation("DemandeRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  description  String
  quantite     Decimal                @default(1) @db.Decimal(10, 2)
  unite        String?
  urgence      NiveauGravite          @default(ATTENTION)
  fournisseur  String?
  statut       StatutDemandeMateriel  @default(DEMANDEE)
  reponseNote  String?
  approverId   String?
  approver     User?                  @relation("DemandeApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approuveLe   DateTime?
  commandeId   String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([chantierId])
  @@index([statut])
  @@index([createdAt(sort: Desc)])
}

// =====================================================
// JOURNAL DE CHANTIER (timeline chat-like)
// =====================================================

enum JournalMessageType {
  NOTE
  SYSTEM_INCIDENT
  /// Incident clos / résolu (le SYSTEM_INCIDENT initial reste, on en ajoute un nouveau)
  SYSTEM_INCIDENT_RESOLU
  SYSTEM_DEMANDE
  SYSTEM_COMMANDE
  /// Commande livrée (transition d'état depuis l'onglet commandes)
  SYSTEM_COMMANDE_LIVREE
  SYSTEM_RAPPORT
  /// Sortie de matériel postée depuis la messagerie (lien sortieId)
  SYSTEM_SORTIE
  /// Retour de matériel — met à jour la sortie liée
  SYSTEM_RETOUR
  /// Location/prêt créé(e) (depuis l'onglet locations)
  SYSTEM_LOCATION
  /// Location/prêt restitué(e) — clôture
  SYSTEM_LOCATION_FIN
  /// Plan uploadé sur le chantier (depuis l'onglet plans)
  SYSTEM_PLAN
  BILAN_JOURNEE
  /// v4.2 : tâche créée depuis un message tagué #tache (lien tacheId)
  SYSTEM_TACHE
  /// v4.2 : réserve de PV créée depuis un message tagué #reserve (lien reserveId)
  SYSTEM_RESERVE
}

// =====================================================
// V4.2 : CANAUX DE MESSAGERIE (vision "Slack de chantier")
// Chaque chantier a des canaux ; la visibilité par canal est ce qui
// permet d'ouvrir la messagerie aux externes (client, sous-traitant)
// sans rien exposer de l'interne. Création réservée conducteur/admin.
// =====================================================

enum CanalVisibility {
  /// Équipe interne uniquement (ADMIN, CONDUCTEUR, CHEF)
  INTERNE
  /// Visible aussi par les comptes CLIENT rattachés au chantier
  CLIENT
  /// Visible aussi par les sous-traitants rattachés au chantier (rôle à venir)
  SOUS_TRAITANT
}

model Canal {
  id          String          @id @default(cuid())
  chantierId  String
  chantier    Chantier        @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  nom         String
  visibility  CanalVisibility @default(INTERNE)
  ordre       Int             @default(0)
  createdById String?
  createdBy   User?           @relation("CanalCreateur", fields: [createdById], references: [id], onDelete: SetNull)
  archivedAt  DateTime?
  createdAt   DateTime        @default(now())

  messages    JournalMessage[]

  @@unique([chantierId, nom])
  @@index([chantierId, ordre])
}

/// v4.2 : tag posé sur un message (catalogue fermé, droits par rôle).
/// entity/entityId matérialisent la fiche créée par le tag (lien
/// message -> fiche générique) ; le fil garde aussi ses colonnes de
/// liaison historiques (incidentId, tacheId...) pour le rendu.
model MessageTag {
  messageId  String
  tagCode    String
  taggedById String?
  taggedBy   User?    @relation("TagAuteur", fields: [taggedById], references: [id], onDelete: SetNull)
  entity     String?
  entityId   String?
  createdAt  DateTime @default(now())

  message    JournalMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, tagCode])
  @@index([entity, entityId])
}

/// Message dans le fil de discussion du chantier (un fil par chantier × jour).
/// Auto-inséré quand un incident, une demande ou une commande est créé(e).
/// Permet aux équipes terrain et aux admins de communiquer au fil de la
/// journée avec photos et vidéos.
/// Suivi de lecture par utilisateur et par "ressource" (un chantier
/// pour la messagerie, "incidents"/"demandes" globalement, etc.).
/// Sert à calculer les badges "non lu" dans la sidebar : un événement
/// créé après `lastReadAt` compte comme non lu.
///
/// Exemples de clés `resource` :
///   - "chantier:<chantierId>"  → la messagerie d'un chantier
///   - "incidents"              → la liste globale des incidents
///   - "demandes"               → les demandes matériel à valider
model UserReadState {
  userId     String
  resource   String
  lastReadAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, resource])
  @@index([userId])
}

model JournalMessage {
  id           String             @id @default(cuid())
  chantierId   String
  chantier     Chantier           @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  authorId     String?
  author       User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  date         DateTime           @db.Date
  type         JournalMessageType @default(NOTE)
  texte        String?
  photos       String[]           @default([])
  videos       String[]           @default([])
  // v4.2 : canal du message (null = messages historiques, rattachés au canal Général par la migration)
  canalId      String?
  canal        Canal?             @relation(fields: [canalId], references: [id], onDelete: SetNull)
  // Liens vers événements existants (pour les messages SYSTEM_*)
  incidentId   String?
  demandeId    String?
  commandeId   String?
  rapportId    String?
  sortieId     String?
  // v4.2 : liens des fiches créées par tag
  tacheId      String?
  reserveId    String?
  // Filtrage avant envoi au client (admin coche/décoche)
  hiddenFromClient Boolean        @default(false)
  // Auteur peut éditer dans les 5 min, admin tout le temps
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([chantierId, date])
  @@index([createdAt(sort: Desc)])
  @@index([canalId])
  reactions    MessageReaction[]
  tags         MessageTag[]
}

/// Réaction emoji sur un message du fil. Un utilisateur peut poser
/// plusieurs emojis différents sur un même message, mais pas le même
/// emoji deux fois (composite PK).
model MessageReaction {
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message JournalMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@index([messageId])
}

// =====================================================
// PLANS DE CHANTIER (fichiers d'aide aux équipes)
// =====================================================

model PlanChantier {
  id           String   @id @default(cuid())
  chantierId   String
  chantier     Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  uploaderId   String
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Restrict)
  nom          String
  description  String?
  fileUrl      String
  mimeType     String
  fileSize     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([chantierId])
}

// =====================================================
// RAPPORT HEBDOMADAIRE (curé par admin avant envoi client)
// =====================================================

model RapportHebdo {
  id                 String   @id @default(cuid())
  chantierId         String
  chantier           Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  semaineDebut       DateTime @db.Date  // lundi de la semaine
  texteIntro         String?
  // Liste des messageIds inclus dans le rapport envoyé au client
  // (par défaut, tous les messages NOTE et BILAN_JOURNEE de la semaine
  //  qui ne sont pas hiddenFromClient. L'admin peut surcharger ici.)
  hiddenMessageIds   String[] @default([])
  envoyeAuClient     Boolean  @default(false)
  envoyeLe           DateTime?
  // Signature électronique : data URL de l'image (PNG du canvas).
  // Le client signe via la page rapport-hebdo, on stocke la signature.
  signatureClientUrl String?
  signatureClientLe  DateTime?
  signatureClientId  String?  // userId qui a signé
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([chantierId, semaineDebut])
}

// =====================================================
// PV de réception (livraison du chantier au client)
// =====================================================

enum StatutPvReception {
  BROUILLON
  ENVOYE_CLIENT
  SIGNE_CLIENT
  RESERVES_LEVEES
}

/// Procès-verbal de réception du chantier. Le client signe la
/// réception, peut lister des réserves (avec photos, position sur plan,
/// zone). Quand toutes les réserves sont levées, le PV passe en
/// RESERVES_LEVEES et le chantier peut être archivé proprement.
model PvReception {
  id                  String           @id @default(cuid())
  chantierId          String
  chantier            Chantier         @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  dateReception       DateTime         @db.Date
  texteRecap          String?
  signatureAdminUrl   String?
  signatureAdminLe    DateTime?
  signatureClientUrl  String?
  signatureClientLe   DateTime?
  statut              StatutPvReception @default(BROUILLON)
  reservesLeveeUrl    String?  // signature finale après levée des réserves
  reservesLeveeLe     DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  plans               PvPlan[]
  reserves            PvReserve[]

  @@unique([chantierId])
}

/// Plan attaché au PV (image PNG/JPG ou PDF). Sert à placer des puces
/// numérotées correspondant aux réserves.
model PvPlan {
  id        String      @id @default(cuid())
  pvId      String
  pv        PvReception @relation(fields: [pvId], references: [id], onDelete: Cascade)
  url       String
  nom       String?
  mimeType  String?
  ordre     Int         @default(0)
  createdAt DateTime    @default(now())

  reserves  PvReserve[]
}

/// Une réserve (élément non-conforme constaté à la réception). Peut être
/// liée à une position sur un plan (puce numérotée) ou simplement à une
/// zone textuelle (ex: "Cuisine"). Photos + commentaire pour documenter.
model PvReserve {
  id          String      @id @default(cuid())
  pvId        String
  pv          PvReception @relation(fields: [pvId], references: [id], onDelete: Cascade)
  numero      Int         // 1, 2, 3... — affiché sur le plan et dans le rapport
  texte       String
  photos      String[]    @default([])
  zone        String?     // localisation textuelle, ex: "Cuisine", "Chambre 1"
  lot         String?     // corps de métier, ex: "NIC", "ACC", "SOL", "FER", "Peinture"
  dateLimite  DateTime?   @db.Date  // "Pour le" — échéance souhaitée pour la levée

  // Position sur un plan (optionnelle)
  planId      String?
  plan        PvPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  posX        Float?      // 0..1 (relatif à la largeur du plan)
  posY        Float?      // 0..1 (relatif à la hauteur du plan)

  // Levée individuelle
  leveLe      DateTime?
  leveNote    String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([pvId, numero])
}

// =====================================================
// WEB PUSH — abonnements navigateur (PWA)
// =====================================================

/// Journal d'audit : trace les actions sensibles (modifications de paie,
/// suppressions, changements de rôle/statut, validations de demandes, etc.)
/// Consultable par les admins via /admin/audit. Append-only (jamais
/// modifié/supprimé) sauf via purge manuelle.
model AuditEntry {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName   String   // snapshot du nom au moment de l'action
  userRole   String   // snapshot du rôle au moment de l'action
  action     String   // ex: "PAIEMENT_PAYE", "USER_DELETED", "DEMANDE_APPROUVEE"
  entity     String   // table/entité touchée : "Paiement", "User", "DemandeMateriel"
  entityId   String?  // id de l'entité ciblée (peut être null si N/A)
  summary    String   // description lisible "Paiement 1234.56€ versé à Jean Dupont"
  metadata   Json?    // payload structuré (avant/après si besoin)

  @@index([createdAt(sort: Desc)])
  @@index([action])
  @@index([entity, entityId])
  @@index([userId])
}

/// Métadonnées EXIF des photos uploadées (GPS, date prise de vue).
/// Indexé par URL relative — une entrée par photo. Optionnel : si l'image
/// ne contient pas d'EXIF GPS, aucune entrée n'est créée.
model PhotoMetadata {
  url       String   @id
  gpsLat    Float?
  gpsLng    Float?
  takenAt   DateTime?
  createdAt DateTime @default(now())

  @@index([gpsLat, gpsLng])
}

/// Chantier épinglé en tête du hub messagerie pour un utilisateur. Composite
/// PK (userId, chantierId) : un user peut épingler plusieurs chantiers,
/// `pinnedAt` sert à ordonner les épinglés entre eux.
model UserChantierPin {
  userId     String
  chantierId String
  pinnedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chantier Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@id([userId, chantierId])
  @@index([userId])
}

/// Abonnement Push d'un navigateur/device. Un utilisateur peut avoir
/// plusieurs subscriptions (téléphone + desktop). Quand un endpoint est
/// révoqué côté navigateur, on supprime l'entrée correspondante.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())

  @@index([userId])
}
