// Outil de Gestion de Chantier - Schéma de base de données

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// AUTHENTIFICATION & UTILISATEURS
// =====================================================

enum Role {
  ADMIN
  /// Conducteur de travaux : voit les prix matériel / locations / commandes,
  /// fait OPC / OPR, valide les demandes, pilote le planning. Ne voit pas
  /// la paie complète. Intermédiaire entre ADMIN et CHEF.
  CONDUCTEUR
  /// Chef de chantier = ouvrier de terrain. Voit son(ses) chantier(s),
  /// son fil, son équipe. Aucun prix nulle part. Peut : pointer, déclarer
  /// incidents, demander matériel, faire rapports avec photos, gérer
  /// sorties/retours matériel.
  CHEF
  CLIENT
  /// v4.3 : compte ultraléger relié à un enregistrement Ouvrier.
  /// Interface réduite au pointage (QR chantier, Arrivée/Départ).
  OUVRIER
  /// v4.3 : externe. Voit son canal, ses tâches/plans, SES documents.
  /// Jamais les prix globaux ni les échanges clients.
  SOUS_TRAITANT
}

enum UserStatus {
  PENDING
  ACTIVE
  REVOKED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(CHEF)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Visibilité côté CLIENT — l'admin contrôle ce que ce client voit.
  // Pour ADMIN/CHEF, ces flags sont ignorés (ils voient tout).
  showJournal       Boolean @default(true)
  showIncidents     Boolean @default(true)
  showPlans         Boolean @default(true)
  showRapportsHebdo Boolean @default(true)
  // Volet contractuel et financier du client (suivi financier). Par DÉFAUT
  // FERMÉ : « le client ne voit que ce qu'on lui ouvre » (vision LYNX v4).
  showDevis         Boolean @default(false)
  showSituations    Boolean @default(false)
  showFactures      Boolean @default(false)

  // 2FA TOTP (RFC 6238). `totpSecret` est en clair (encryption au repos
  // via la BDD/disk). `totpEnabled` reste false tant que le user n'a pas
  // vérifié son premier code (anti-enrôlement raté). Backup codes hashés
  // SHA-256, à usage unique : on vérifie le hash et on retire le code.
  totpEnabled     Boolean  @default(false)
  totpSecret      String?
  totpBackupCodes String[] @default([])

  chantiersGeres      Chantier[]           @relation("ChefChantier")
  chantiersClient     Chantier[]           @relation("ChantierClients")
  tempsPasses         TempsPasse[]
  espaces             EspaceMembre[]
  passwordResets      PasswordResetToken[]
  rapportsCrees       RapportChantier[]
  incidentsRapportes  Incident[]           @relation("IncidentReporter")
  incidentsResolus    Incident[]           @relation("IncidentResolver")
  demandesFaites      DemandeMateriel[]    @relation("DemandeRequester")
  demandesValidees    DemandeMateriel[]    @relation("DemandeApprover")
  notifications       Notification[]
  journalMessages     JournalMessage[]
  plansUploaded       PlanChantier[]
  readStates          UserReadState[]
  pushSubscriptions   PushSubscription[]
  chantierPins        UserChantierPin[]
  auditEntries        AuditEntry[]
  messageReactions    MessageReaction[]
  canauxCrees         Canal[]              @relation("CanalCreateur")
  messageTags         MessageTag[]         @relation("TagAuteur")
  chantiersMembre     ChantierMembre[]     @relation("MembreUser")
  membresAjoutes      ChantierMembre[]     @relation("MembreAjoutePar")
  canauxMembre        CanalMembre[]        @relation("CanalMembreUser")
  canalMembresAjoutes CanalMembre[]        @relation("CanalMembreAjoutePar")
  ouvrierLie          Ouvrier?
  // Suivi financier (2026-07-08) : maître d'ouvrage / client rattaché à un doc.
  marchesClient       Marche[]             @relation("MarcheClient")
  devisClient         Devis[]              @relation("DevisClient")
  facturesClient      Facture[]            @relation("FactureClient")
  tachesPerso         Tache[]              @relation("TachesPerso")
  affairesResponsable Affaire[]            @relation("AffairesResponsable")
  affairesClient      Affaire[]            @relation("AffairesClient")
}

/// v4.3 : une ligne = une personne sur un chantier, quel que soit son
/// chapeau (le rôle reste global sur User). L'admin voit tout sans
/// lignes ; conducteurs, chefs, ouvriers, sous-traitants et clients ne
/// voient que les chantiers où ils sont membres. Ajout et retrait par
/// l'admin ou un conducteur membre du chantier.
model ChantierMembre {
  id         String   @id @default(cuid())
  chantierId String
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("MembreUser", fields: [userId], references: [id], onDelete: Cascade)
  addedById  String?
  addedBy    User?    @relation("MembreAjoutePar", fields: [addedById], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@unique([chantierId, userId])
  @@index([userId])
}

/// v4.3 : composition explicite d'un canal. Le canal Général n'a pas de
/// lignes : l'équipe interne du chantier y est de droit. Borne dure
/// appliquée côté action : un externe n'est invitable que sur un canal
/// de sa classe (CLIENT -> CLIENT, SOUS_TRAITANT -> SOUS_TRAITANT).
model CanalMembre {
  canalId   String
  canal     Canal    @relation(fields: [canalId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("CanalMembreUser", fields: [userId], references: [id], onDelete: Cascade)
  addedById String?
  addedBy   User?    @relation("CanalMembreAjoutePar", fields: [addedById], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@id([canalId, userId])
  @@index([userId])
}

// Token à usage unique pour réinitialiser un mot de passe.
// `tokenHash` = hash SHA-256 du token (le token clair est dans l'URL envoyée).
// On ne stocke jamais le token clair en base.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// =====================================================
// CHANTIERS, ÉQUIPES, OUVRIERS
// =====================================================

enum StatutChantier {
  PLANIFIE
  EN_COURS
  PAUSE
  TERMINE
  ANNULE
}

/// Projets typés (VISION-LYNX-V4) : une étude de bureau d'études EST un
/// Chantier de type ETUDE. Elle hérite messagerie, canaux, membres, tâches
/// et plans ; le type sert de GABARIT (canaux par défaut, modules visibles).
enum TypeProjet {
  CHANTIER
  ETUDE
}

model Chantier {
  id             String         @id @default(cuid())
  nom            String
  adresse        String?
  description    String?
  dateDebut      DateTime?
  dateFin        DateTime?
  statut         StatutChantier @default(PLANIFIE)
  type           TypeProjet     @default(CHANTIER)
  espaceId       String
  espace         Espace         @relation(fields: [espaceId], references: [id], onDelete: Restrict)
  budgetEspeces  Decimal        @default(0) @db.Decimal(12, 2)
  budgetVirement Decimal        @default(0) @db.Decimal(12, 2)
  chefId         String?
  chef           User?          @relation("ChefChantier", fields: [chefId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  archivedAt DateTime?

  equipes          Equipe[]
  pointages        Pointage[]
  sortiesMateriel  SortieMateriel[]
  locations        LocationPret[]
  commandes        Commande[]
  taches           Tache[]
  rapports         RapportChantier[]
  incidents        Incident[]
  demandesMateriel DemandeMateriel[]
  clients          User[]             @relation("ChantierClients")
  journalMessages  JournalMessage[]
  plans            PlanChantier[]
  rapportsHebdo    RapportHebdo[]
  pvReceptions     PvReception[]
  labels           Label[]
  sections         Section[]
  pins             UserChantierPin[]
  canaux           Canal[]
  membres          ChantierMembre[]
  phasesEtude      PhaseEtude[]
  tempsPasses      TempsPasse[]
  // Suivi financier (2026-07-08)
  marches          Marche[]
  devis            Devis[]
  situations       SituationTravaux[]
  factures         Facture[]
  retenues         RetenueGarantie[]
  // GED chantier (2026-07-11)
  documents        ChantierDocument[]
  prelevementLabos PrelevementLabo[]
  // CRM (2026-07-17) : affaires converties vers ce chantier
  affaires         Affaire[]

  @@index([type])
  @@index([espaceId])
}

model Equipe {
  id         String    @id @default(cuid())
  nom        String
  chantierId String?
  chantier   Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  /// Socle espaces : l'annuaire appartient à une entreprise. Nullable en
  /// base (SetNull), mais backfillé et posé à la création : les listes
  /// bornées par espace ne montrent jamais les lignes NULL.
  espaceId   String?
  espace     Espace?   @relation(fields: [espaceId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  ouvriers        Ouvrier[]
  sortiesMateriel SortieMateriel[]
  taches          Tache[]

  @@index([espaceId])
}

enum TypeContrat {
  FIXE
  JOUR
  SEMAINE
  MOIS
  FORFAIT
}

enum ModePaie {
  JOUR
  SEMAINE
  MOIS
}

model Ouvrier {
  id          String      @id @default(cuid())
  nom         String
  prenom      String?
  telephone   String?
  photo       String?
  typeContrat TypeContrat
  tarifBase   Decimal     @db.Decimal(10, 2)
  modePaie    ModePaie    @default(MOIS)
  actif       Boolean     @default(true)
  equipeId    String?
  equipe      Equipe?     @relation(fields: [equipeId], references: [id], onDelete: SetNull)
  /// v4.3 : compte OUVRIER lié (pointage QR). Optionnel : un ouvrier
  /// sans smartphone reste un simple enregistrement pointé par le chef.
  userId      String?     @unique
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Socle espaces : un ouvrier est salarié d'UNE entreprise (annuaire et
  /// paie bornés par espace). Même régime que Equipe.espaceId.
  espaceId    String?
  espace      Espace?     @relation(fields: [espaceId], references: [id], onDelete: SetNull)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  pointages        Pointage[]
  avances          Avance[]
  paiements        Paiement[]
  outilsPersonnels OutilPersonnel[]
  tachesAssignees  TacheOuvrier[]
  documents        OuvrierDocument[]

  @@index([espaceId])
}

/// GED ouvrier (2026-07-11) : CV, habilitations, contrats, pieces d'identite,
/// visites medicales... Fichiers servis via /uploads/docs-ouvriers.
enum CategorieDocOuvrier {
  CV
  HABILITATION
  CONTRAT
  IDENTITE
  MEDICAL
  AUTRE
}

model OuvrierDocument {
  id        String              @id @default(cuid())
  ouvrierId String
  ouvrier   Ouvrier             @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  nom       String
  categorie CategorieDocOuvrier @default(AUTRE)
  fichier   String
  mimeType  String?
  taille    Int?
  note      String?
  createdAt DateTime            @default(now())
  creePar   String?

  @@index([ouvrierId])
}

/// GED chantier (2026-07-11) : plans, contrats, devis, PV... avec circuit de
/// signature client (reutilise le SignaturePad du PV de reception).
enum CategorieDocChantier {
  PLAN
  CONTRAT
  DEVIS
  FACTURE
  PV
  RAPPORT
  AUTRE
}

enum StatutSignatureDoc {
  SANS
  A_SIGNER
  SIGNE
}

model ChantierDocument {
  id                 String               @id @default(cuid())
  chantierId         String
  chantier           Chantier             @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  nom                String
  categorie          CategorieDocChantier @default(AUTRE)
  fichier            String
  mimeType           String?
  taille             Int?
  note               String?
  /// Visible par les comptes CLIENT du chantier (fiche + /mes-documents).
  visibleClient      Boolean              @default(false)
  statutSignature    StatutSignatureDoc   @default(SANS)
  signatureClientUrl String?
  signatureClientLe  DateTime?
  signatureClientPar String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  creePar            String?

  @@index([chantierId])
  @@index([chantierId, categorie])
  @@index([statutSignature])
}

/// Singleton (id="singleton") qui stocke les préférences de l'app —
/// modifiables par un admin depuis /parametres.
model AppSettings {
  id              String   @id @default("singleton")
  joursParMois    Int      @default(23)
  joursParSemaine Int      @default(6)
  modePaieDefault String   @default("ESPECES") // ESPECES | VIREMENT
  nomEntreprise   String?
  updatedAt       DateTime @updatedAt
}

model Pointage {
  id              String    @id @default(cuid())
  ouvrierId       String
  ouvrier         Ouvrier   @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  date            DateTime  @db.Date
  joursTravailles Decimal   @default(1) @db.Decimal(4, 2)
  chantierId      String?
  chantier        Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  note            String?
  photo           String?
  createdAt       DateTime  @default(now())

  @@unique([ouvrierId, date])
  @@index([date])
  @@index([chantierId])
}

enum ModePaiement {
  ESPECES
  VIREMENT
  // Suivi financier (2026-07-08) : moyens d'encaissement client courants.
  CHEQUE
  CB
  EFFET
}

model Avance {
  id         String       @id @default(cuid())
  ouvrierId  String
  ouvrier    Ouvrier      @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  montant    Decimal      @db.Decimal(10, 2)
  date       DateTime     @db.Date
  mode       ModePaiement @default(ESPECES)
  reglee     Boolean      @default(false)
  paiementId String?
  paiement   Paiement?    @relation(fields: [paiementId], references: [id], onDelete: SetNull)
  note       String?
  createdAt  DateTime     @default(now())

  @@index([ouvrierId])
  @@index([reglee])
}

enum StatutPaiement {
  CALCULE
  PAYE
  ANNULE
}

model Paiement {
  id              String         @id @default(cuid())
  ouvrierId       String
  ouvrier         Ouvrier        @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  periodeDebut    DateTime       @db.Date
  periodeFin      DateTime       @db.Date
  joursTravailles Decimal        @db.Decimal(6, 2)
  montantBrut     Decimal        @db.Decimal(10, 2)
  avancesDeduites Decimal        @default(0) @db.Decimal(10, 2)
  retenueOutil    Decimal        @default(0) @db.Decimal(10, 2)
  montantNet      Decimal        @db.Decimal(10, 2)
  mode            ModePaiement   @default(ESPECES)
  date            DateTime       @db.Date
  statut          StatutPaiement @default(CALCULE)
  note            String?
  createdAt       DateTime       @default(now())

  avances        Avance[]
  retenuesOutils RetenueOutil[]

  @@index([ouvrierId, periodeDebut])
}

model OutilPersonnel {
  id         String   @id @default(cuid())
  ouvrierId  String
  ouvrier    Ouvrier  @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  nom        String
  prixTotal  Decimal  @db.Decimal(10, 2)
  mensualite Decimal  @db.Decimal(10, 2)
  restantDu  Decimal  @db.Decimal(10, 2)
  dateAchat  DateTime @db.Date
  solde      Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  retenues RetenueOutil[]

  @@index([ouvrierId, solde])
}

model RetenueOutil {
  id               String         @id @default(cuid())
  outilPersonnelId String
  outilPersonnel   OutilPersonnel @relation(fields: [outilPersonnelId], references: [id], onDelete: Cascade)
  paiementId       String
  paiement         Paiement       @relation(fields: [paiementId], references: [id], onDelete: Cascade)
  montant          Decimal        @db.Decimal(10, 2)
  createdAt        DateTime       @default(now())
}

// =====================================================
// MATÉRIEL, ACCESSOIRES, SORTIES, LOCATIONS
// =====================================================

enum StatutMateriel {
  DISPO
  SORTI
  EN_LOCATION
  HS
  PERDU
}

enum PossesseurMateriel {
  ENTREPRISE
  LOCATION
  PRET
}

model Materiel {
  id          String             @id @default(cuid())
  nomCommun   String
  marque      String?
  modele      String?
  numeroSerie String?
  photo       String?
  statut      StatutMateriel     @default(DISPO)
  possesseur  PossesseurMateriel @default(ENTREPRISE)
  prixAchat   Decimal?           @db.Decimal(10, 2)
  dateAchat   DateTime?          @db.Date
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  accessoires Accessoire[]
  sorties     SortieMateriel[]
  locations   LocationPret[]

  @@index([statut])
  @@index([possesseur])
}

model Accessoire {
  id         String   @id @default(cuid())
  materielId String
  materiel   Materiel @relation(fields: [materielId], references: [id], onDelete: Cascade)
  type       String
  nom        String
  quantite   Int      @default(1)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum EtatRetour {
  BON
  USE
  CASSE
  MANQUANT
}

model SortieMateriel {
  id         String      @id @default(cuid())
  materielId String
  materiel   Materiel    @relation(fields: [materielId], references: [id], onDelete: Cascade)
  equipeId   String?
  equipe     Equipe?     @relation(fields: [equipeId], references: [id], onDelete: SetNull)
  chantierId String?
  chantier   Chantier?   @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  dateSortie DateTime    @default(now())
  dateRetour DateTime?
  etatRetour EtatRetour?
  note       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([materielId, dateRetour])
  @@index([equipeId])
}

enum TypeLocationPret {
  LOCATION
  PRET
}

model LocationPret {
  id             String           @id @default(cuid())
  materielId     String?
  materiel       Materiel?        @relation(fields: [materielId], references: [id], onDelete: SetNull)
  designation    String
  type           TypeLocationPret
  fournisseurNom String
  chantierId     String?
  chantier       Chantier?        @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  dateDebut      DateTime         @db.Date
  dateFinPrevue  DateTime         @db.Date
  dateRetourReel DateTime?        @db.Date
  coutJour       Decimal          @default(0) @db.Decimal(10, 2)
  coutTotal      Decimal          @default(0) @db.Decimal(10, 2)
  cloture        Boolean          @default(false)
  note           String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([cloture, dateFinPrevue])
}

// =====================================================
// COMMANDES
// =====================================================

enum StatutCommande {
  COMMANDEE
  EN_LIVRAISON
  LIVREE
  ANNULEE
}

model Commande {
  id                  String         @id @default(cuid())
  chantierId          String
  chantier            Chantier       @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  fournisseur         String
  reference           String?
  coutTotal           Decimal        @default(0) @db.Decimal(12, 2)
  dateCommande        DateTime       @db.Date
  dateLivraisonPrevue DateTime?      @db.Date
  dateLivraisonReelle DateTime?      @db.Date
  statut              StatutCommande @default(COMMANDEE)
  mode                ModePaiement   @default(VIREMENT)
  note                String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  lignes LigneCommande[]

  // Soft-delete : marqué supprimé mais conservé 30 jours dans la corbeille
  deletedAt DateTime?

  @@index([chantierId])
  @@index([statut])
  @@index([deletedAt])
}

model LigneCommande {
  id           String   @id @default(cuid())
  commandeId   String
  commande     Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  designation  String
  quantite     Decimal  @default(1) @db.Decimal(10, 2)
  prixUnitaire Decimal  @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(12, 2)
}

// =====================================================
// PLANNING / TÂCHES
// =====================================================

enum StatutTache {
  A_FAIRE
  EN_COURS
  TERMINEE
  BLOQUEE
}

model Tache {
  id             String         @id @default(cuid())
  /// Nullable depuis 2026-07-14 : une tache PERSO n'a pas de chantier, elle
  /// appartient a son proprietaire (proprietaireId) et n'est visible que
  /// de lui. Invariant applicatif : chantierId OU proprietaireId renseigne.
  chantierId     String?
  chantier       Chantier?      @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  proprietaireId String?
  proprietaire   User?          @relation("TachesPerso", fields: [proprietaireId], references: [id], onDelete: Cascade)
  /// Tache issue d'une AFFAIRE (CRM) : "qualifier ce client", "faire la
  /// visite"... Portee par le proprietaire (tache perso) et reliee ici.
  affaireId      String?
  affaire        Affaire?       @relation(fields: [affaireId], references: [id], onDelete: SetNull)
  equipeId       String?
  equipe         Equipe?        @relation(fields: [equipeId], references: [id], onDelete: SetNull)
  nom            String
  description    String?
  dateDebut      DateTime       @db.Date
  dateFin        DateTime       @db.Date
  avancement     Int            @default(0)
  statut         StatutTache    @default(A_FAIRE)
  /// Priorité Todoist-style : 1 = P1 (urgent, rouge), 2 = P2 (haute, orange),
  /// 3 = P3 (moyenne, bleu), 4 = P4 (par défaut, gris).
  priorite       Int            @default(4)
  /// Sous-tâche : pointe vers la tâche parente. Cascade delete.
  parentId       String?
  parent         Tache?         @relation("TacheSousTaches", fields: [parentId], references: [id], onDelete: Cascade)
  enfants        Tache[]        @relation("TacheSousTaches")
  /// Ordre manuel dans la liste (drag-to-reorder dans l'UI).
  ordre          Int            @default(0)
  /// Groupe de regroupement façon Todoist (ex: "Gros œuvre", "Finitions").
  /// Par chantier ; SetNull si la section est supprimée.
  sectionId      String?
  section        Section?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  dependances    Tache[]        @relation("TacheDependance")
  dependants     Tache[]        @relation("TacheDependance")
  labels         TacheLabel[]
  ouvriers       TacheOuvrier[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Récurrence (format RFC 5545 RRULE, ex: "FREQ=WEEKLY;BYDAY=MO,FR").
  // Quand la tâche est marquée terminée, une nouvelle occurrence est
  // créée automatiquement à la prochaine date prévue par la règle.
  recurrence         String?
  /// Tâche parente de la série récurrente (pour traçage/historique).
  recurrenceParentId String?
  /// Position manuelle du noeud dans le reseau PERT (2026-07-11) : posee par
  /// glisser-deposer, partagee par toute l'equipe. NULL = disposition
  /// automatique par niveaux (barycentre).
  pertX              Float?
  pertY              Float?

  // Soft-delete : marqué supprimé mais conservé 30 jours dans la corbeille
  deletedAt DateTime?

  @@index([chantierId])
  @@index([dateDebut, dateFin])
  @@index([parentId])
  @@index([sectionId])
  @@index([deletedAt])
}

/// Affectation m2m d'ouvriers sur une tâche. La tâche garde toujours son
/// équipe (vue agrégée), mais cette table permet de cibler des ouvriers
/// individuels — utile pour les sous-tâches précises ou les forfaits.
model TacheOuvrier {
  tacheId   String
  ouvrierId String
  tache     Tache    @relation(fields: [tacheId], references: [id], onDelete: Cascade)
  ouvrier   Ouvrier  @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([tacheId, ouvrierId])
  @@index([ouvrierId])
}

/// Section pour grouper les tâches dans un chantier (Todoist-like).
/// Exemples : "Gros œuvre", "Second œuvre", "Finitions", "VRD".
model Section {
  id         String   @id @default(cuid())
  chantierId String
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  nom        String
  couleur    String? // hex optionnel pour accent visuel
  ordre      Int      @default(0)
  taches     Tache[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chantierId])
}

/// Étiquette / tag pour catégoriser les tâches (sécurité, urgent, livraison...).
/// Globale par défaut (chantierId null) ou rattachée à un chantier.
model Label {
  id         String       @id @default(cuid())
  nom        String
  couleur    String       @default("#3b82f6") // hex
  chantierId String?
  chantier   Chantier?    @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  taches     TacheLabel[]
  createdAt  DateTime     @default(now())

  @@index([chantierId])
}

/// Table de jointure many-to-many Tache ↔ Label.
model TacheLabel {
  tacheId String
  labelId String
  tache   Tache  @relation(fields: [tacheId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([tacheId, labelId])
  @@index([labelId])
}

// =====================================================
// RAPPORTS DE CHANTIER (DSR — Daily Site Report)
// =====================================================

enum Meteo {
  SOLEIL
  NUAGEUX
  PLUIE
  ORAGE
  NEIGE
  GEL
  VENT_FORT
}

/// Rapport journalier rédigé par un chef de chantier (ou admin) sur
/// un chantier : ce qui a été fait, météo, photos prises sur site,
/// nombre d'ouvriers présents. Permet à l'admin de suivre l'avancement
/// sans être sur place.
model RapportChantier {
  id         String   @id @default(cuid())
  chantierId String
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  date       DateTime @db.Date
  meteo      Meteo?
  texte      String
  photos     String[] @default([])
  nbOuvriers Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Soft-delete : marqué supprimé mais conservé 30 jours dans la corbeille
  deletedAt DateTime?

  @@index([chantierId, date(sort: Desc)])
  @@index([authorId])
  @@index([deletedAt])
}

// =====================================================
// INCIDENTS / ISSUES (problèmes terrain)
// =====================================================

enum CategorieIncident {
  MATERIEL_MANQUANT
  PANNE
  METEO
  RETARD_FOURNISSEUR
  SECURITE
  ACCIDENT
  CONFLIT
  AUTRE
}

enum NiveauGravite {
  INFO
  ATTENTION
  URGENT
}

enum StatutIncident {
  OUVERT
  EN_COURS
  RESOLU
}

/// Incident remonté depuis le terrain : matériel manquant, panne,
/// problème météo, retard fournisseur, sécurité, accident, etc.
/// Permet aux chefs de signaler les blocages, et aux admins de suivre
/// la résolution.
model Incident {
  id             String            @id @default(cuid())
  chantierId     String?
  chantier       Chantier?         @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  reporterId     String
  reporter       User              @relation("IncidentReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  titre          String
  description    String
  categorie      CategorieIncident
  gravite        NiveauGravite     @default(ATTENTION)
  statut         StatutIncident    @default(OUVERT)
  resolutionNote String?
  resolvedAt     DateTime?
  resolverId     String?
  resolver       User?             @relation("IncidentResolver", fields: [resolverId], references: [id], onDelete: SetNull)
  photos         String[]          @default([])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([chantierId])
  @@index([statut])
  @@index([createdAt(sort: Desc)])
}

// =====================================================
// NOTIFICATIONS IN-APP
// =====================================================

enum NotificationType {
  RAPPORT_CREE
  INCIDENT_OUVERT
  INCIDENT_RESOLU
  DEMANDE_CREEE
  DEMANDE_APPROUVEE
  DEMANDE_REFUSEE
  DEMANDE_COMMANDEE
  PAIEMENT_GENERE
  USER_PENDING
  RELANCE
  AUTRE
}

/// Notification simple pour l'utilisateur, affichée dans la cloche en
/// haut de page. Créée par notify() depuis les server actions concernées.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt(sort: Desc)])
}

// =====================================================
// DEMANDES DE MATÉRIEL (chef demande → admin valide → commande)
// =====================================================

enum StatutDemandeMateriel {
  DEMANDEE
  APPROUVEE
  REFUSEE
  COMMANDEE
}

/// Demande de matériel formulée par un chef de chantier. L'admin valide
/// (ou refuse), puis la transforme en commande quand elle part chez le
/// fournisseur. Workflow propre : trace tout, évite les SMS perdus.
model DemandeMateriel {
  id          String                @id @default(cuid())
  chantierId  String
  chantier    Chantier              @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User                  @relation("DemandeRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  description String
  quantite    Decimal               @default(1) @db.Decimal(10, 2)
  unite       String?
  urgence     NiveauGravite         @default(ATTENTION)
  fournisseur String?
  statut      StatutDemandeMateriel @default(DEMANDEE)
  reponseNote String?
  approverId  String?
  approver    User?                 @relation("DemandeApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approuveLe  DateTime?
  commandeId  String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([chantierId])
  @@index([statut])
  @@index([createdAt(sort: Desc)])
}

// =====================================================
// JOURNAL DE CHANTIER (timeline chat-like)
// =====================================================

enum JournalMessageType {
  NOTE
  SYSTEM_INCIDENT
  /// Incident clos / résolu (le SYSTEM_INCIDENT initial reste, on en ajoute un nouveau)
  SYSTEM_INCIDENT_RESOLU
  SYSTEM_DEMANDE
  SYSTEM_COMMANDE
  /// Commande livrée (transition d'état depuis l'onglet commandes)
  SYSTEM_COMMANDE_LIVREE
  SYSTEM_RAPPORT
  /// Sortie de matériel postée depuis la messagerie (lien sortieId)
  SYSTEM_SORTIE
  /// Retour de matériel — met à jour la sortie liée
  SYSTEM_RETOUR
  /// Location/prêt créé(e) (depuis l'onglet locations)
  SYSTEM_LOCATION
  /// Location/prêt restitué(e) — clôture
  SYSTEM_LOCATION_FIN
  /// Plan uploadé sur le chantier (depuis l'onglet plans)
  SYSTEM_PLAN
  BILAN_JOURNEE
  /// v4.2 : tâche créée depuis un message tagué #tache (lien tacheId)
  SYSTEM_TACHE
  /// v4.2 : réserve de PV créée depuis un message tagué #reserve (lien reserveId)
  SYSTEM_RESERVE
}

// =====================================================
// V4.2 : CANAUX DE MESSAGERIE (vision "Slack de chantier")
// Chaque chantier a des canaux ; la visibilité par canal est ce qui
// permet d'ouvrir la messagerie aux externes (client, sous-traitant)
// sans rien exposer de l'interne. Création réservée conducteur/admin.
// =====================================================

enum CanalVisibility {
  /// Équipe interne uniquement (ADMIN, CONDUCTEUR, CHEF)
  INTERNE
  /// Visible aussi par les comptes CLIENT rattachés au chantier
  CLIENT
  /// Visible aussi par les sous-traitants rattachés au chantier (rôle à venir)
  SOUS_TRAITANT
}

model Canal {
  id          String          @id @default(cuid())
  /// Nullable depuis 2026-07-17 : un canal appartient a un CHANTIER ou a
  /// une AFFAIRE (CRM). Invariant applicatif : exactement l'un des deux.
  chantierId  String?
  chantier    Chantier?       @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  affaireId   String?
  affaire     Affaire?        @relation(fields: [affaireId], references: [id], onDelete: Cascade)
  nom         String
  visibility  CanalVisibility @default(INTERNE)
  ordre       Int             @default(0)
  createdById String?
  createdBy   User?           @relation("CanalCreateur", fields: [createdById], references: [id], onDelete: SetNull)
  archivedAt  DateTime?
  createdAt   DateTime        @default(now())

  messages JournalMessage[]
  membres  CanalMembre[]

  @@unique([chantierId, nom])
  @@index([chantierId, ordre])
}

/// v4.2 : tag posé sur un message (catalogue fermé, droits par rôle).
/// entity/entityId matérialisent la fiche créée par le tag (lien
/// message -> fiche générique) ; le fil garde aussi ses colonnes de
/// liaison historiques (incidentId, tacheId...) pour le rendu.
model MessageTag {
  messageId  String
  tagCode    String
  taggedById String?
  taggedBy   User?    @relation("TagAuteur", fields: [taggedById], references: [id], onDelete: SetNull)
  entity     String?
  entityId   String?
  createdAt  DateTime @default(now())

  message JournalMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, tagCode])
  @@index([entity, entityId])
}

/// Message dans le fil de discussion du chantier (un fil par chantier × jour).
/// Auto-inséré quand un incident, une demande ou une commande est créé(e).
/// Permet aux équipes terrain et aux admins de communiquer au fil de la
/// journée avec photos et vidéos.
/// Suivi de lecture par utilisateur et par "ressource" (un chantier
/// pour la messagerie, "incidents"/"demandes" globalement, etc.).
/// Sert à calculer les badges "non lu" dans la sidebar : un événement
/// créé après `lastReadAt` compte comme non lu.
///
/// Exemples de clés `resource` :
///   - "chantier:<chantierId>"  → la messagerie d'un chantier
///   - "incidents"              → la liste globale des incidents
///   - "demandes"               → les demandes matériel à valider
model UserReadState {
  userId     String
  resource   String
  lastReadAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, resource])
  @@index([userId])
}

model JournalMessage {
  id               String             @id @default(cuid())
  /// Nullable depuis 2026-07-17 : un message d'un canal d'AFFAIRE n'a pas
  /// de chantier ; son ancrage est le canal (canalId) et l'affaire du canal.
  chantierId       String?
  chantier         Chantier?          @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  authorId         String?
  author           User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  date             DateTime           @db.Date
  type             JournalMessageType @default(NOTE)
  texte            String?
  photos           String[]           @default([])
  videos           String[]           @default([])
  /// Mémos vocaux : fichiers audio bruts (dossier /uploads/audios)
  audios           String[]           @default([])
  /// Pièces jointes documentaires : tableau JSON [{ url, nom, mimeType, taille }]
  documents        Json               @default("[]")
  // v4.2 : canal du message (null = messages historiques, rattachés au canal Général par la migration)
  canalId          String?
  canal            Canal?             @relation(fields: [canalId], references: [id], onDelete: SetNull)
  // Liens vers événements existants (pour les messages SYSTEM_*)
  incidentId       String?
  demandeId        String?
  commandeId       String?
  rapportId        String?
  sortieId         String?
  // v4.2 : liens des fiches créées par tag
  tacheId          String?
  reserveId        String?
  // Filtrage avant envoi au client (admin coche/décoche)
  hiddenFromClient Boolean            @default(false)
  // Auteur peut éditer dans les 5 min, admin tout le temps
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  reactions        MessageReaction[]
  tags             MessageTag[]

  @@index([chantierId, date])
  @@index([createdAt(sort: Desc)])
  @@index([canalId])
}

/// Réaction emoji sur un message du fil. Un utilisateur peut poser
/// plusieurs emojis différents sur un même message, mais pas le même
/// emoji deux fois (composite PK).
model MessageReaction {
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message JournalMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@index([messageId])
}

// =====================================================
// PLANS DE CHANTIER (fichiers d'aide aux équipes)
// =====================================================

model PlanChantier {
  id          String   @id @default(cuid())
  chantierId  String
  chantier    Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Restrict)
  nom         String
  description String?
  /// Type de plan personnalisable (2026-07-18) : saisie libre au dépôt,
  /// suggestions tirées des types déjà employés sur le chantier.
  type        String?
  fileUrl     String
  mimeType    String
  fileSize    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([chantierId])
  @@index([chantierId, type])
}

// =====================================================
// RAPPORT HEBDOMADAIRE (curé par admin avant envoi client)
// =====================================================

model RapportHebdo {
  id                 String    @id @default(cuid())
  chantierId         String
  chantier           Chantier  @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  semaineDebut       DateTime  @db.Date // lundi de la semaine
  texteIntro         String?
  // Liste des messageIds inclus dans le rapport envoyé au client
  // (par défaut, tous les messages NOTE et BILAN_JOURNEE de la semaine
  //  qui ne sont pas hiddenFromClient. L'admin peut surcharger ici.)
  hiddenMessageIds   String[]  @default([])
  envoyeAuClient     Boolean   @default(false)
  envoyeLe           DateTime?
  // Signature électronique : data URL de l'image (PNG du canvas).
  // Le client signe via la page rapport-hebdo, on stocke la signature.
  signatureClientUrl String?
  signatureClientLe  DateTime?
  signatureClientId  String? // userId qui a signé
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([chantierId, semaineDebut])
}

// =====================================================
// PV de réception (livraison du chantier au client)
// =====================================================

enum StatutPvReception {
  BROUILLON
  ENVOYE_CLIENT
  SIGNE_CLIENT
  RESERVES_LEVEES
}

/// Procès-verbal de réception du chantier. Le client signe la
/// réception, peut lister des réserves (avec photos, position sur plan,
/// zone). Quand toutes les réserves sont levées, le PV passe en
/// RESERVES_LEVEES et le chantier peut être archivé proprement.
model PvReception {
  id                 String            @id @default(cuid())
  chantierId         String
  chantier           Chantier          @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  dateReception      DateTime          @db.Date
  texteRecap         String?
  signatureAdminUrl  String?
  signatureAdminLe   DateTime?
  signatureClientUrl String?
  signatureClientLe  DateTime?
  statut             StatutPvReception @default(BROUILLON)
  reservesLeveeUrl   String? // signature finale après levée des réserves
  reservesLeveeLe    DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  plans    PvPlan[]
  reserves PvReserve[]

  @@unique([chantierId])
}

/// Plan attaché au PV (image PNG/JPG ou PDF). Sert à placer des puces
/// numérotées correspondant aux réserves.
model PvPlan {
  id        String      @id @default(cuid())
  pvId      String
  pv        PvReception @relation(fields: [pvId], references: [id], onDelete: Cascade)
  url       String
  nom       String?
  mimeType  String?
  ordre     Int         @default(0)
  createdAt DateTime    @default(now())

  reserves PvReserve[]
}

/// Une réserve (élément non-conforme constaté à la réception). Peut être
/// liée à une position sur un plan (puce numérotée) ou simplement à une
/// zone textuelle (ex: "Cuisine"). Photos + commentaire pour documenter.
model PvReserve {
  id         String      @id @default(cuid())
  pvId       String
  pv         PvReception @relation(fields: [pvId], references: [id], onDelete: Cascade)
  numero     Int // 1, 2, 3... — affiché sur le plan et dans le rapport
  texte      String
  photos     String[]    @default([])
  zone       String? // localisation textuelle, ex: "Cuisine", "Chambre 1"
  lot        String? // corps de métier, ex: "NIC", "ACC", "SOL", "FER", "Peinture"
  dateLimite DateTime?   @db.Date // "Pour le" — échéance souhaitée pour la levée

  // Position sur un plan (optionnelle)
  planId String?
  plan   PvPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  posX   Float? // 0..1 (relatif à la largeur du plan)
  posY   Float? // 0..1 (relatif à la hauteur du plan)

  // Levée individuelle
  leveLe   DateTime?
  leveNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pvId, numero])
}

// =====================================================
// WEB PUSH — abonnements navigateur (PWA)
// =====================================================

/// Journal d'audit : trace les actions sensibles (modifications de paie,
/// suppressions, changements de rôle/statut, validations de demandes, etc.)
/// Consultable par les admins via /admin/audit. Append-only (jamais
/// modifié/supprimé) sauf via purge manuelle.
model AuditEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName  String // snapshot du nom au moment de l'action
  userRole  String // snapshot du rôle au moment de l'action
  action    String // ex: "PAIEMENT_PAYE", "USER_DELETED", "DEMANDE_APPROUVEE"
  entity    String // table/entité touchée : "Paiement", "User", "DemandeMateriel"
  entityId  String? // id de l'entité ciblée (peut être null si N/A)
  summary   String // description lisible "Paiement 1234.56€ versé à Jean Dupont"
  metadata  Json? // payload structuré (avant/après si besoin)

  @@index([createdAt(sort: Desc)])
  @@index([action])
  @@index([entity, entityId])
  @@index([userId])
}

/// Métadonnées EXIF des photos uploadées (GPS, date prise de vue).
/// Indexé par URL relative — une entrée par photo. Optionnel : si l'image
/// ne contient pas d'EXIF GPS, aucune entrée n'est créée.
model PhotoMetadata {
  url       String    @id
  gpsLat    Float?
  gpsLng    Float?
  takenAt   DateTime?
  createdAt DateTime  @default(now())

  @@index([gpsLat, gpsLng])
}

/// Chantier épinglé en tête du hub messagerie pour un utilisateur. Composite
/// PK (userId, chantierId) : un user peut épingler plusieurs chantiers,
/// `pinnedAt` sert à ordonner les épinglés entre eux.
model UserChantierPin {
  userId     String
  chantierId String
  pinnedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chantier Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@id([userId, chantierId])
  @@index([userId])
}

/// Abonnement Push d'un navigateur/device. Un utilisateur peut avoir
/// plusieurs subscriptions (téléphone + desktop). Quand un endpoint est
/// révoqué côté navigateur, on supprime l'entrée correspondante.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())

  @@index([userId])
}

// ─── Bureau d'études (phase 1 du module BE, 2026-07-07) ─────────────────────
// Ce qui est PROPRE au BE : phases d'honoraires et temps passés. Le reste
// (messagerie, membres, tâches, plans) vient du Chantier typé ETUDE.

/// Phase d'honoraires d'une étude (ESQ, APS, APD, PRO, DCE, EXE, VISA, DET...,
/// code libre) : montant vendu et budget d'heures pour le prévu/réel.
model PhaseEtude {
  id           String    @id @default(cuid())
  chantierId   String
  chantier     Chantier  @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  code         String
  libelle      String
  montantVendu Decimal   @default(0) @db.Decimal(12, 2)
  budgetHeures Decimal?  @db.Decimal(7, 2)
  dateDebut    DateTime?
  dateFin      DateTime?
  ordre        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tempsPasses TempsPasse[]
  situations  SituationTravaux[]

  @@index([chantierId, ordre])
}

/// Temps passé par une personne sur une étude (la matière première vendue
/// d'un BE) : saisie de la veille en deux clics, phase facultative.
model TempsPasse {
  id         String      @id @default(cuid())
  chantierId String
  chantier   Chantier    @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  phaseId    String?
  phase      PhaseEtude? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime    @db.Date
  heures     Decimal     @db.Decimal(4, 2)
  note       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId, date])
  @@index([chantierId, date])
}

// ─── Socle plateforme : ESPACES (arbitrage du 2026-07-07) ───────────────────
// Une entreprise = un espace (modèle Odoo : une seule app, une seule base,
// sélecteur d entreprise, modules activables par espace, rôle PAR espace).
// La séparation des équipes chantier / bureau d études se joue ici.

model Espace {
  id        String   @id @default(cuid())
  nom       String
  slug      String   @unique
  couleur   String?
  /// Identité pour l'entête des documents (charte : « l'entête de ses
  /// documents ») : logo uploadé + coordonnées de l'entreprise.
  logoUrl   String?
  adresse   String?
  telephone String?
  email     String?
  siret     String?
  /// Modules (apps) actifs : "chantier", "be" (extensible : "permis"...).
  modules   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membres          EspaceMembre[]
  chantiers        Chantier[]
  ouvriers         Ouvrier[]
  equipes          Equipe[]
  // Suivi financier (2026-07-08)
  marches          Marche[]
  devis            Devis[]
  situations       SituationTravaux[]
  factures         Facture[]
  encaissements    Encaissement[]
  retenues         RetenueGarantie[]
  formulationLabos FormulationLabo[]
  prelevementLabos PrelevementLabo[]
  equipementLabos  EquipementLabo[]
  affaires         Affaire[]
}

/// Adhésion d un utilisateur à un espace, avec un rôle PROPRE à cet espace
/// (une projeteuse peut être CHEF côté BE et ne pas exister côté chantier).
model EspaceMembre {
  id        String   @id @default(cuid())
  espaceId  String
  espace    Espace   @relation(fields: [espaceId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @default(CHEF)
  createdAt DateTime @default(now())

  @@unique([espaceId, userId])
  @@index([userId])
}

// ─── Suivi financier (2026-07-08) ────────────────────────────────────────────
// LYNX SUIT le cycle commercial et financier des projets (devis, marché,
// situations de travaux, factures, acomptes, encaissements, retenue de
// garantie) sans GÉNÉRER les pièces : elles naissent dans Odoo (EcoTech) ou
// Constructor (Autonhome). Chaque enregistrement porte un statut, des montants,
// des dates et une référence externe (numéro + lien/PDF). Un seul moteur de
// calcul (src/lib/suivi-commercial.ts) dérive les KPI (reste à encaisser, DSO,
// avancement facturé vs travaux) ; rien de dérivé n'est saisi.
// Tout objet naît rattaché à un Espace (espaceId, borné par espaceFilter) et
// dérive d'un Chantier (chantierId), la frontière d'espace étant posée par les
// gardes requireChantierAccess/Manager avant le court-circuit admin.

enum SourceDoc {
  ODOO
  CONSTRUCTOR
  MANUEL
  AUTRE
}

enum NatureMarche {
  PRIVE
  PUBLIC
}

enum TypePrix {
  FERME
  FERME_ACTUALISABLE
  REVISABLE
}

enum ModeEcheance {
  DATE_FACTURE
  FIN_DE_MOIS
}

/// Un marché de travaux se facture par SITUATION_TRAVAUX (avancement) ; un
/// marché d'honoraires (BE) se facture par JALON_PHASE (ESQ/APS/.../DET/AOR).
enum ModeFacturation {
  SITUATION_TRAVAUX
  JALON_PHASE
}

enum StatutMarche {
  BROUILLON
  ACTIF
  RECEPTIONNE
  SOLDE
  CLOTURE
}

enum StatutDevis {
  BROUILLON
  ENVOYE
  RELANCE
  ACCEPTE
  REFUSE
  EXPIRE
}

/// Base de calcul du % d'avancement d'une situation : le montant du marché
/// (travaux) ou le forfait d'une phase d'honoraires (BE).
enum BaseAvancement {
  BASE_TRAVAUX
  BASE_FORFAIT_PHASE
}

/// Cycle de visa propre au BTP (distinct du cycle de règlement d'une facture) :
/// une situation est transmise, visée par la maîtrise d'œuvre, acceptée, puis
/// facturée et payée.
enum StatutSituation {
  BROUILLON
  TRANSMISE
  VISEE_MOE
  ACCEPTEE
  FACTUREE
  PAYEE
  PARTIELLEMENT_PAYEE
  CONTESTEE
}

enum TypeFacture {
  ACOMPTE
  SITUATION
  SOLDE
  HONORAIRES
  AVOIR
}

/// Deux axes ORTHOGONAUX sur une facture (modèle account.move d'Odoo) : l'état
/// documentaire (émission) et l'état de règlement. EN_RETARD n'est JAMAIS
/// stocké : il se dérive (non payé ET échéance dépassée), les bornes de jour
/// étant en UTC comme partout dans le dépôt (dates @db.Date à minuit UTC).
enum StatutEmission {
  BROUILLON
  EMISE
  ENVOYEE
  ANNULEE
}

enum StatutReglement {
  NON_PAYEE
  PARTIELLEMENT_PAYEE
  PAYEE
  ANNULEE
}

enum FormeGarantie {
  RETENUE_FONDS
  CAUTION_PERSO_SOLIDAIRE
  GARANTIE_PREMIERE_DEMANDE
}

enum StatutRetenue {
  RETENUE
  CONSIGNEE
  CAUTIONNEE
  LIBEREE
  OPPOSITION
}

/// Marché (contrat) : PIVOT du suivi. Son montant courant (initial + avenants
/// signés) est le « vendu » officiel, base de calcul de l'avancement. Remplace,
/// à terme, les champs budget saisis à la main sur Chantier.
model Marche {
  id         String   @id @default(cuid())
  espaceId   String
  espace     Espace   @relation(fields: [espaceId], references: [id], onDelete: Restrict)
  chantierId String
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  reference        String
  natureMarche     NatureMarche    @default(PRIVE)
  modeFacturation  ModeFacturation @default(SITUATION_TRAVAUX)
  // Maître d'ouvrage / client : un User CLIENT LYNX quand il existe, sinon libre.
  clientUserId     String?
  clientUser       User?           @relation("MarcheClient", fields: [clientUserId], references: [id], onDelete: SetNull)
  maitreOuvrageNom String?

  montantInitialHT Decimal  @default(0) @db.Decimal(12, 2)
  montantCourantHT Decimal  @default(0) @db.Decimal(12, 2)
  typePrix         TypePrix @default(FERME)

  tauxRetenueGarantie       Decimal      @default(0) @db.Decimal(5, 2)
  delaiPaiementJours        Int          @default(30)
  modeCalculEcheance        ModeEcheance @default(DATE_FACTURE)
  periodiciteSituationsMois Int          @default(1)

  dateSignature DateTime?
  statut        StatutMarche @default(BROUILLON)
  note          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  creePar       String?

  devis      Devis[]
  avenants   Avenant[]
  situations SituationTravaux[]
  factures   Facture[]
  retenue    RetenueGarantie?

  @@index([espaceId])
  @@index([chantierId])
  @@index([statut])
}

/// Avenant : modifie le montant courant du marché (signé, +/-).
model Avenant {
  id            String    @id @default(cuid())
  marcheId      String
  marche        Marche    @relation(fields: [marcheId], references: [id], onDelete: Cascade)
  numero        Int
  objet         String
  montantHT     Decimal   @db.Decimal(12, 2)
  dateSignature DateTime?
  signe         Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([marcheId])
}

/// Devis SUIVI (miroir d'un devis créé ailleurs). À l'acceptation, il initialise
/// ou se rattache à un Marché.
model Devis {
  id           String    @id @default(cuid())
  espaceId     String
  espace       Espace    @relation(fields: [espaceId], references: [id], onDelete: Restrict)
  chantierId   String?
  chantier     Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  marcheId     String?
  marche       Marche?   @relation(fields: [marcheId], references: [id], onDelete: SetNull)
  clientUserId String?
  clientUser   User?     @relation("DevisClient", fields: [clientUserId], references: [id], onDelete: SetNull)

  source           SourceDoc @default(MANUEL)
  referenceExterne String?
  lienExterne      String?
  fichierPdf       String?
  objet            String

  montantHT  Decimal @default(0) @db.Decimal(12, 2)
  montantTVA Decimal @default(0) @db.Decimal(12, 2)
  montantTTC Decimal @default(0) @db.Decimal(12, 2)

  statut          StatutDevis @default(BROUILLON)
  dateEmission    DateTime?
  dateEnvoi       DateTime?
  dateValidite    DateTime?
  dateAcceptation DateTime?
  dateRefus       DateTime?
  motifRefus      String?

  nbRelances          Int       @default(0)
  dateDerniereRelance DateTime?
  prochaineRelance    DateTime?

  // Signature électronique du client (acceptation du devis). PNG data URL,
  // horodaté et attribué, comme les rapports hebdo / PV (valeur probante :
  // signature simple recevable, art. 1367 Code civil).
  signatureClientUrl String?
  signatureClientLe  DateTime?
  signatureClientId  String?
  signatureClientNom String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creePar   String?

  factures Facture[]

  @@index([espaceId])
  @@index([chantierId])
  @@index([statut])
}

/// Situation de travaux (facturation à l'avancement) OU jalon d'honoraires (BE) :
/// même objet, discriminé par `base`. Le moteur calcule montantPeriodeHT =
/// (référence x avancementCumulePct / 100) - montantCumuleAnterieurHT.
model SituationTravaux {
  id           String         @id @default(cuid())
  espaceId     String
  espace       Espace         @relation(fields: [espaceId], references: [id], onDelete: Restrict)
  chantierId   String
  chantier     Chantier       @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  marcheId     String
  marche       Marche         @relation(fields: [marcheId], references: [id], onDelete: Cascade)
  base         BaseAvancement @default(BASE_TRAVAUX)
  phaseEtudeId String?
  phaseEtude   PhaseEtude?    @relation(fields: [phaseEtudeId], references: [id], onDelete: SetNull)

  numeroOrdre       Int
  periodeDebut      DateTime @db.Date
  periodeFin        DateTime @db.Date
  dateEtablissement DateTime @db.Date

  avancementCumulePct      Decimal @db.Decimal(5, 2)
  montantReferenceHT       Decimal @db.Decimal(12, 2)
  montantCumuleHT          Decimal @db.Decimal(12, 2)
  montantCumuleAnterieurHT Decimal @default(0) @db.Decimal(12, 2)
  montantPeriodeHT         Decimal @db.Decimal(12, 2)
  retenueGarantiePeriode   Decimal @default(0) @db.Decimal(12, 2)
  imputationAcompte        Decimal @default(0) @db.Decimal(12, 2)
  tauxTVA                  Decimal @default(20) @db.Decimal(5, 2)
  autoliquidation          Boolean @default(false)
  netAPayerPeriode         Decimal @db.Decimal(12, 2)

  statut        StatutSituation @default(BROUILLON)
  dateVisaMOE   DateTime?
  valideurMoeId String?

  // Signature du client (acceptation de l'avancement / bon à payer de la
  // demande d'acompte). Même dispositif que le devis et les rapports.
  signatureClientUrl String?
  signatureClientLe  DateTime?
  signatureClientId  String?
  signatureClientNom String?

  factureId String?  @unique
  facture   Facture? @relation("FactureSituation", fields: [factureId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creePar   String?

  @@unique([marcheId, numeroOrdre])
  @@index([espaceId])
  @@index([chantierId])
  @@index([statut])
}

/// Facture SUIVIE. Double statut (émission + règlement). Une facture de type
/// SITUATION peut être rattachée à une SituationTravaux ; un AVOIR pointe la
/// facture qu'il corrige.
model Facture {
  id           String    @id @default(cuid())
  espaceId     String
  espace       Espace    @relation(fields: [espaceId], references: [id], onDelete: Restrict)
  chantierId   String?
  chantier     Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  marcheId     String?
  marche       Marche?   @relation(fields: [marcheId], references: [id], onDelete: SetNull)
  devisId      String?
  devis        Devis?    @relation(fields: [devisId], references: [id], onDelete: SetNull)
  clientUserId String?
  clientUser   User?     @relation("FactureClient", fields: [clientUserId], references: [id], onDelete: SetNull)

  type             TypeFacture @default(SITUATION)
  avoirDeFactureId String?
  avoirDe          Facture?    @relation("Avoir", fields: [avoirDeFactureId], references: [id], onDelete: SetNull)
  avoirs           Facture[]   @relation("Avoir")

  source           SourceDoc @default(MANUEL)
  referenceExterne String?
  lienExterne      String?
  fichierPdf       String?
  objet            String?

  montantHT              Decimal @default(0) @db.Decimal(12, 2)
  montantTVA             Decimal @default(0) @db.Decimal(12, 2)
  montantTTC             Decimal @default(0) @db.Decimal(12, 2)
  autoliquidation        Boolean @default(false)
  retenueGarantieMontant Decimal @default(0) @db.Decimal(12, 2)
  montantPaye            Decimal @default(0) @db.Decimal(12, 2)

  statutEmission  StatutEmission  @default(BROUILLON)
  statutReglement StatutReglement @default(NON_PAYEE)

  dateEmission        DateTime?
  dateEcheance        DateTime? @db.Date
  dateEnvoi           DateTime?
  datePaiementComplet DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creePar   String?

  situationLiee SituationTravaux? @relation("FactureSituation")
  encaissements Encaissement[]

  @@index([espaceId])
  @@index([chantierId])
  @@index([statutReglement])
  @@index([dateEcheance])
}

/// Encaissement (règlement reçu) rattaché à UNE facture (partiel supporté par
/// montant < TTC). Le lettrage multi-factures est reporté à un lot ultérieur.
model Encaissement {
  id         String  @id @default(cuid())
  espaceId   String
  espace     Espace  @relation(fields: [espaceId], references: [id], onDelete: Restrict)
  chantierId String?
  factureId  String
  facture    Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  montant          Decimal      @db.Decimal(12, 2)
  dateEncaissement DateTime     @db.Date
  mode             ModePaiement @default(VIREMENT)
  reference        String?
  createdAt        DateTime     @default(now())
  creePar          String?

  @@index([espaceId])
  @@index([factureId])
}

/// Retenue de garantie : encours « gelé » suivi par marché. Plafond légal privé
/// 5 % (loi 71-584), libérée un an après réception, remplaçable par une caution.
model RetenueGarantie {
  id         String   @id @default(cuid())
  espaceId   String
  espace     Espace   @relation(fields: [espaceId], references: [id], onDelete: Restrict)
  chantierId String
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  marcheId   String   @unique
  marche     Marche   @relation(fields: [marcheId], references: [id], onDelete: Cascade)

  tauxPct                Decimal       @default(5) @db.Decimal(5, 2)
  montantRetenuCumul     Decimal       @default(0) @db.Decimal(12, 2)
  forme                  FormeGarantie @default(RETENUE_FONDS)
  dateDebut              DateTime?
  dateEcheanceLiberation DateTime?
  statut                 StatutRetenue @default(RETENUE)
  dateLiberation         DateTime?
  motifOpposition        String?
  organismeCaution       String?
  referenceCaution       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([espaceId])
  @@index([chantierId])
  @@index([statut])
}

/// Moteur de relances financieres (2026-07-13). Chaque constat notifie
/// s'inscrit ici : un objet n'est relance qu'UNE fois par palier
/// (idempotence du balayage quotidien) et le journal reste consultable.
enum TypeObjetRelance {
  FACTURE
  DEVIS
  SITUATION
  RETENUE
  ESSAI
  AFFAIRE
}

enum PalierRelance {
  PREAVIS_ECHEANCE
  RELANCE_1
  RELANCE_2
  RELANCE_3
  MISE_EN_DEMEURE
  DEVIS_SANS_REPONSE
  SITUATION_A_FACTURER
  RETENUE_LIBERABLE
  ESSAI_ECHU
  AFFAIRE_DORMANTE
}

model RelanceLog {
  id         String           @id @default(cuid())
  espaceId   String
  chantierId String?
  objetType  TypeObjetRelance
  objetId    String
  palier     PalierRelance
  resume     String
  envoyeLe   DateTime         @default(now())

  @@unique([objetType, objetId, palier])
  @@index([espaceId, envoyeLe])
}

/// Module Laboratoire V1 (2026-07-14, OptimusLab). Deux flux sur un meme
/// noyau : essais chantier (beton, echeances J+7/J+28) et R&D par
/// formulation (terre crue, biosources, protocole libre). Voir
/// docs/CONCEPTION-LABO.md.
enum StatutEssaiLabo {
  PLANIFIE
  EN_COURS
  VALIDE
  ANNULE
}

model FormulationLabo {
  id          String   @id @default(cuid())
  espaceId    String
  espace      Espace   @relation(fields: [espaceId], references: [id], onDelete: Cascade)
  nom         String
  campagne    String?
  description String?
  composition String?
  createdAt   DateTime @default(now())
  creePar     String?

  prelevements PrelevementLabo[]

  @@index([espaceId])
}

model PrelevementLabo {
  id              String           @id @default(cuid())
  espaceId        String
  espace          Espace           @relation(fields: [espaceId], references: [id], onDelete: Cascade)
  chantierId      String?
  chantier        Chantier?        @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  formulationId   String?
  formulation     FormulationLabo? @relation(fields: [formulationId], references: [id], onDelete: SetNull)
  reference       String
  materiau        String
  origine         String?
  datePrelevement DateTime         @db.Date
  preleveur       String?
  /// Classe prescrite pour le flux beton (ex. C25/30) : sert au verdict
  /// de conformite des essais de compression.
  classePrescrite String?
  note            String?
  createdAt       DateTime         @default(now())
  creePar         String?

  eprouvettes EprouvetteLabo[]
  essais      EssaiLabo[]

  @@index([espaceId])
  @@index([chantierId])
  @@index([formulationId])
}

model EprouvetteLabo {
  id              String          @id @default(cuid())
  prelevementId   String
  prelevement     PrelevementLabo @relation(fields: [prelevementId], references: [id], onDelete: Cascade)
  code            String          @unique
  geometrie       String?
  dateFabrication DateTime?       @db.Date
  conditionsCure  String?

  essais EssaiLabo[]

  @@index([prelevementId])
}

model EquipementLabo {
  id             String    @id @default(cuid())
  espaceId       String
  espace         Espace    @relation(fields: [espaceId], references: [id], onDelete: Cascade)
  nom            String
  dateEtalonnage DateTime? @db.Date
  note           String?

  essais EssaiLabo[]

  @@index([espaceId])
}

model EssaiLabo {
  id              String          @id @default(cuid())
  prelevementId   String
  prelevement     PrelevementLabo @relation(fields: [prelevementId], references: [id], onDelete: Cascade)
  eprouvetteId    String?
  eprouvette      EprouvetteLabo? @relation(fields: [eprouvetteId], references: [id], onDelete: SetNull)
  equipementId    String?
  equipement      EquipementLabo? @relation(fields: [equipementId], references: [id], onDelete: SetNull)
  /// Type d'essai (compression, flexion, granulometrie, teneur en eau...).
  type            String
  /// Norme (ex. NF EN 12390-3) OU protocole libre : les deux champs
  /// coexistent, la terre crue et les biosources n'ayant pas de
  /// protocole consensuel (XP P13-901, guides).
  norme           String?
  protocole       String?
  echeance        DateTime?       @db.Date
  statut          StatutEssaiLabo @default(PLANIFIE)
  operateur       String?
  dateRealisation DateTime?       @db.Date
  /// Resultat V1 integre a l'essai (un resultat par essai).
  valeur          Decimal?        @db.Decimal(12, 4)
  unite           String?
  incertitude     String?
  seuil           Decimal?        @db.Decimal(12, 4)
  conforme        Boolean?
  note            String?
  createdAt       DateTime        @default(now())
  creePar         String?

  @@index([prelevementId])
  @@index([echeance])
  @@index([statut])
}

/// CRM Affaires (2026-07-17). Le pipeline commercial de LYNX : une affaire
/// suit un prospect de la prise de contact au marche gagne, par TYPOLOGIE
/// (les etapes de chaque typologie vivent en constantes TS, peu d'etapes,
/// discipline de la prochaine action datee). A la victoire : conversion en
/// chantier. Chaque affaire a son CANAL de messagerie.
enum TypologieAffaire {
  PERMIS_CONSTRUIRE
  ETUDE_STRUCTURE
  TRAVAUX
  LABO
}

enum StatutAffaire {
  EN_COURS
  GAGNEE
  PERDUE
}

model Affaire {
  id                String           @id @default(cuid())
  espaceId          String
  espace            Espace           @relation(fields: [espaceId], references: [id], onDelete: Cascade)
  titre             String
  typologie         TypologieAffaire
  etapeCle          String
  etapeDepuis       DateTime         @default(now())
  statut            StatutAffaire    @default(EN_COURS)
  motifPerte        String?
  contactNom        String
  contactTel        String?
  contactEmail      String?
  adresse           String?
  description       String?
  valeurEstimee     Decimal?         @db.Decimal(12, 2)
  prochaineAction   String?
  prochaineActionLe DateTime?        @db.Date
  responsableId     String?
  responsable       User?            @relation("AffairesResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  checklist         Json             @default("[]")
  /// Dossiers personnalisés du dossier client (2026-07-18) : tableau de
  /// { cle, libelle }. Les documents y sont rattachés par dossierPerso.
  dossiersPerso     Json             @default("[]")
  clientUserId      String?
  clientUser        User?            @relation("AffairesClient", fields: [clientUserId], references: [id], onDelete: SetNull)
  chantierId        String?
  chantier          Chantier?        @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  creePar           String?

  canaux    Canal[]
  taches    Tache[]
  documents AffaireDocument[]

  @@index([espaceId, statut])
  @@index([typologie, etapeCle])
  @@index([responsableId])
  @@index([prochaineActionLe])
}

/// GED d'affaire (2026-07-17) : l'arborescence du dossier client, alimentee
/// automatiquement par les pieces jointes du canal de messagerie. Chaque
/// document vit dans un sous-dossier (categorie) et peut valider une piece
/// de la checklist (checklistCle).
enum CategorieDocAffaire {
  PHOTOS
  PIECES_CLIENT
  CONCEPTION
  DEVIS
  LIVRABLES
  AUTRE
}

model AffaireDocument {
  id           String              @id @default(cuid())
  affaireId    String
  affaire      Affaire             @relation(fields: [affaireId], references: [id], onDelete: Cascade)
  categorie    CategorieDocAffaire @default(AUTRE)
  /// Cle de la piece de checklist validee par ce document (ex. cadastre).
  checklistCle String?
  /// Cle d'un dossier personnalisé de l'affaire (Affaire.dossiersPerso) :
  /// non nul, le document appartient à ce dossier ; nul, à sa catégorie.
  dossierPerso String?
  nom          String
  fichier      String
  mimeType     String?
  taille       Int?
  note         String?
  /// Message du fil d'ou vient la piece (traçabilite du rangement).
  messageId    String?
  createdAt    DateTime            @default(now())
  creePar      String?

  // Idempotence du rangement tenue en BASE : une même pièce d'un même
  // message ne peut être rangée qu'une fois, même si deux soumissions se
  // chevauchent (deux onglets, retry). NULLs distincts en Postgres : les
  // dépôts directs (messageId null) ne sont pas contraints.
  @@unique([affaireId, messageId, fichier])
  @@index([affaireId, categorie])
  @@index([affaireId, checklistCle])
  @@index([affaireId, dossierPerso])
}
