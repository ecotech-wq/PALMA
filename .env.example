# Base de données
DATABASE_URL="postgresql://ogc:ogc_dev_password@localhost:5433/ogc?schema=public"

# Auth.js
# Générer avec: openssl rand -base64 32
AUTH_SECRET="changez-moi-en-production-avec-un-secret-aleatoire-de-32-octets"
AUTH_TRUST_HOST=true

# URL publique de l'app
NEXTAUTH_URL="http://localhost:3000"

# Admin par défaut créé par le seed
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Administrateur"

# Relances financières : secret du déclencheur HTTP externe
# (POST /api/cron/relances avec l'en-tête "Authorization: Bearer <valeur>").
# Facultatif : le cron interne (6 h 30, heure de Maurice) tourne sans lui.
# Générer avec: openssl rand -base64 32
# CRON_SECRET="changez-moi-avec-un-secret-aleatoire-long"
