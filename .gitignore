# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production builds
/build
/backups
*.sql.gz
# (les .sql de prisma/migrations/ doivent être commités → on ne les ignore PAS)

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (les .example sont commités)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client
/src/generated/prisma

# uploads utilisateurs (volumes Docker en prod, jamais committés)
/public/uploads/materiel/*
/public/uploads/ouvriers/*
!/public/uploads/materiel/.gitkeep
!/public/uploads/ouvriers/.gitkeep

# Claude Code / agents locaux
/.claude/

# IDE
/.idea
/.vscode
