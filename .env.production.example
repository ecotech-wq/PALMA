# =====================================================================
# Configuration production — à remplir et renommer en .env.production
# Chargé automatiquement par : docker compose -f docker-compose.prod.yml --env-file .env.production
# =====================================================================

# Sous-domaine où l'app sera accessible (DNS A record → IP du VPS)
APP_DOMAIN=chantier.ton-domaine.com

# Email pour les certificats Let's Encrypt (alertes expiration)
ACME_EMAIL=ton-email@example.com

# Postgres : choisis un mot de passe FORT (ex: 32+ caractères aléatoires)
# Génère-le avec : openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_GENERER_AVEC_OPENSSL

# Secret pour Auth.js / NextAuth — DOIT être un secret aléatoire, pas de mot.
# Génère-le avec : openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERER_AVEC_OPENSSL_RAND

# =====================================================================
# Reverse proxy hôte + épinglage des volumes (CRITIQUE sur une prod existante)
# ---------------------------------------------------------------------
# Si un reverse proxy (nginx) tourne déjà sur l'hôte (cas de autonhome-vps),
# Caddy reste en profil désactivé et l'app est publiée sur 127.0.0.1:APP_LOCAL_PORT.
APP_LOCAL_PORT=3010
# Noms des volumes Docker EXISTANTS. NE PAS les changer sur une prod en service :
# un renommage monte des volumes NEUFS et VIDES à la place des données réelles
# (incident du 2026-07-02). Valeurs de la prod actuelle :
POSTGRES_VOLUME_NAME=app_autonhome_postgres
UPLOADS_VOLUME_NAME=app_autonhome_uploads

# =====================================================================
# Web Push (optionnel) — notifications navigateur. Générer une paire :
#   npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY doit être égal à VAPID_PUBLIC_KEY (inliné au build).
# =====================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=

# Admin initial (utilisé une seule fois par docker/seed-admin.cjs)
SEED_ADMIN_EMAIL=admin@autonhome.local
SEED_ADMIN_NAME=Administrateur
# Si vide, un mot de passe sera généré et affiché lors du seed
SEED_ADMIN_PASSWORD=

# =====================================================================
# SMTP (optionnel) — pour l'envoi des emails de réinitialisation MdP
# Si vide, les liens de reset ne sont pas envoyés par email mais affichés
# à l'admin dans /admin/users (mode "fallback").
# Avec Hostinger Email, les valeurs sont typiquement :
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=ton-email@ton-domaine.com
#   SMTP_PASS=mot-de-passe-de-l-email
#   SMTP_FROM=Autonhome <noreply@ton-domaine.com>
# =====================================================================
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
