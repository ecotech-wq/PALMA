# Caddy : reverse proxy avec HTTPS automatique (Let's Encrypt).
# Le domaine et l'email sont injectés depuis docker-compose via env vars.

{
  email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
  encode gzip zstd

  # Cache long pour les assets statiques générés par Next
  @static {
    path /_next/static/* /icons/* /brand/* /manifest.webmanifest /sw.js /favicon.ico
  }
  header @static Cache-Control "public, max-age=31536000, immutable"
  # Le service worker doit pouvoir être mis à jour rapidement
  header /sw.js Cache-Control "public, max-age=0, must-revalidate"

  # En-têtes de sécurité
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(self), geolocation=(), microphone=()"
    -Server
  }

  reverse_proxy app:3000 {
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}
  }
}
