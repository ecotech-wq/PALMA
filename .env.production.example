# =====================================================================
# Configuration production — à remplir et renommer en .env.production
# Chargé automatiquement par : docker compose -f docker-compose.prod.yml --env-file .env.production
# =====================================================================

# Sous-domaine où l'app sera accessible (DNS A record → IP du VPS)
APP_DOMAIN=chantier.ton-domaine.com

# Email pour les certificats Let's Encrypt (alertes expiration)
ACME_EMAIL=ton-email@example.com

# Postgres : choisis un mot de passe FORT (ex: 32+ caractères aléatoires)
# Génère-le avec : openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_GENERER_AVEC_OPENSSL

# Secret pour Auth.js / NextAuth — DOIT être un secret aléatoire, pas de mot.
# Génère-le avec : openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERER_AVEC_OPENSSL_RAND

# Admin initial (utilisé une seule fois par docker/seed-admin.mjs)
SEED_ADMIN_EMAIL=admin@autonhome.local
SEED_ADMIN_NAME=Administrateur
# Si vide, un mot de passe sera généré et affiché lors du seed
SEED_ADMIN_PASSWORD=
